from snakemake.utils import min_version

# Minimum Snakemake version needed for the storage plugins used in remote_files.smk
min_version("8.0.0")

include: "../shared/vendored/snakemake/config.smk"

configfile: os.path.join(workflow.basedir, "defaults/config.yaml")

if os.path.exists("config.yaml"):
    configfile: "config.yaml"

include: "rules/config.smk"

builds = config['builds']

wildcard_constraints:
    build = "|".join(builds),
    build_with_underscores = "|".join(b.replace('/', '_') for b in builds),
    gene = "|".join(set([get_gene(b) for b in builds]))

rule all:
    input:
        auspice_json = [f"auspice/measles_{b.replace('/', '_')}.json" for b in builds],
        tip_frequencies_json = [f"auspice/measles_{b.replace('/', '_')}_tip-frequencies.json" for b in builds]

include: "../shared/vendored/snakemake/remote_files.smk"
include: "rules/merge_inputs.smk"
include: "rules/prepare_sequences.smk"
include: "rules/construct_phylogeny.smk"
include: "rules/annotate_phylogeny.smk"
include: "rules/export.smk"

# Include custom rules defined in the config.
if "custom_rules" in config:
    for rule_file in config["custom_rules"]:

        include: os.path.join(os.getcwd(), rule_file)

rule clean:
    """Removing directories: {params}"""
    params:
        "results ",
        "auspice"
    shell:
        "rm -rfv {params}"
